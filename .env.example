DATABASE_URL="postgresql://kanban:kanban@localhost:5432/kanban?schema=public"
# Conexão DIRETA (sem pooler) usada só por `prisma migrate deploy`. No Neon é o host
# sem "-pooler". Evita P1002 (advisory lock do migrate quebra sobre o pooler).
# Em local pode omitir — cai no DATABASE_URL.
DIRECT_URL="postgresql://kanban:kanban@localhost:5432/kanban?schema=public"
MCP_TOKEN="troque-este-token"

# Vercel Blob — anexos/imagens dos cards. Crie um Blob store no Vercel (Storage) e conecte o projeto.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxx"

# Clerk (auth) — chaves no dashboard.clerk.com (ou rode: npx clerk@latest init)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxx"
CLERK_SECRET_KEY="sk_test_xxx"
