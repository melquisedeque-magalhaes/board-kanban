generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Priority {
  CRITICA
  ALTA
  MEDIA
  BAIXA
}

enum CardType {
  BUG
  FEATURE
  TAREFA
}

model Board {
  id        String   @id @default(cuid())
  name      String
  columns   Column[]
  createdAt DateTime @default(now())
}

model Column {
  id       String  @id @default(cuid())
  boardId  String
  board    Board   @relation(fields: [boardId], references: [id], onDelete: Cascade)
  name     String
  color    String?
  position Float
  cards    Card[]
}

model Card {
  id          String    @id @default(cuid())
  columnId    String
  column      Column    @relation(fields: [columnId], references: [id], onDelete: Cascade)
  code        String?
  title       String
  details     String?   @db.Text
  priority    Priority?
  type        CardType?
  version     String?
  dueDate     DateTime?
  archivedAt  DateTime?
  position    Float
  assignees   User[]    @relation("CardAssignees")
  labels      Label[]   @relation("CardLabels")
  comments    Comment[]
  attachments Attachment[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([archivedAt])
}

model Attachment {
  id          String   @id @default(cuid())
  cardId      String
  card        Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  commentId   String?
  comment     Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  url         String
  name        String
  contentType String?
  size        Int?
  createdAt   DateTime @default(now())

  @@index([cardId])
  @@index([commentId])
}

model User {
  id               String    @id @default(cuid())
  clerkId          String?   @unique
  name             String
  email            String?   @unique
  avatarUrl        String?
  profileCustomized Boolean  @default(false)
  cards            Card[]    @relation("CardAssignees")
  comments         Comment[]
}

model Label {
  id    String @id @default(cuid())
  name  String
  color String
  cards Card[] @relation("CardLabels")
}

model Comment {
  id          String       @id @default(cuid())
  cardId      String
  card        Card         @relation(fields: [cardId], references: [id], onDelete: Cascade)
  authorId    String?
  author      User?        @relation(fields: [authorId], references: [id])
  body        String       @db.Text
  attachments Attachment[]
  createdAt   DateTime     @default(now())
}
